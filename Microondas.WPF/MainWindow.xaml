<Window x:Class="Microondas.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Microondas.WPF"
        mc:Ignorable="d"
        Title="Simulador de Microondas" Height="940" Width="450"
        Background="#2D2D30" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="BotaoPrograma" TargetType="Button">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#007ACC"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="BotaoAcao" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BotaoTeclado" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Background" Value="#4A4A4D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#007ACC"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="MICROONDAS"
                   FontSize="22" FontWeight="Bold"
                   Foreground="White" HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="#1E1E1E"
                BorderBrush="#007ACC" BorderThickness="3"
                CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TempoFormatado}"
                               FontSize="44" FontFamily="Consolas"
                               Foreground="#00FF00" FontWeight="Bold"/>
                    <TextBlock Text="  P:"
                               FontSize="20" Foreground="#00FF00"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PowerLevel}"
                               FontSize="32" FontFamily="Consolas"
                               Foreground="#00FF00" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="{Binding AnimacaoTexto}"
                           FontSize="18" FontFamily="Consolas"
                           Foreground="#FFD700"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="5">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Tempo (1-120s)" Foreground="White"
                                   HorizontalAlignment="Center" FontSize="11"/>
                        <Border Background="#1E1E1E" BorderThickness="2" CornerRadius="3" Padding="5"
                                BorderBrush="{Binding CampoAtivo, Converter={x:Null}, FallbackValue=#007ACC}"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding SelecionarCampoCommand}"
                                              CommandParameter="tempo"/>
                            </Border.InputBindings>
                            <TextBlock Text="{Binding TempoInputText, TargetNullValue='--'}"
                                       FontSize="20" FontFamily="Consolas"
                                       Foreground="#00FF00" HorizontalAlignment="Center"
                                       MinWidth="50" TextAlignment="Center"/>
                        </Border>
                        <TextBlock Text="segundos" Foreground="Gray"
                                   HorizontalAlignment="Center" FontSize="9"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Potência (1-10)" Foreground="White"
                                   HorizontalAlignment="Center" FontSize="11"/>
                        <Border Background="#1E1E1E" BorderThickness="2" CornerRadius="3" Padding="5"
                                BorderBrush="{Binding CampoAtivo, Converter={x:Null}, FallbackValue=#555}"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding SelecionarCampoCommand}"
                                              CommandParameter="potencia"/>
                            </Border.InputBindings>
                            <TextBlock Text="{Binding PotenciaInputText, TargetNullValue='10'}"
                                       FontSize="20" FontFamily="Consolas"
                                       Foreground="#00FF00" HorizontalAlignment="Center"
                                       MinWidth="50" TextAlignment="Center"/>
                        </Border>
                        <TextBlock Text="nível" Foreground="Gray"
                                   HorizontalAlignment="Center" FontSize="9"/>
                    </StackPanel>
                </Grid>

                <TextBlock Foreground="#FFD700" HorizontalAlignment="Center" FontSize="10" Margin="0,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="► Digitando: TEMPO"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CampoAtivo}" Value="potencia">
                                    <Setter Property="Text" Value="► Digitando: POTÊNCIA"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <Border Grid.Column="1" Background="#3E3E42" CornerRadius="5" Padding="5" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Teclado" Foreground="White" HorizontalAlignment="Center" 
                               FontSize="10" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="1"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="2"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="3"/>

                        <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="4"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="5"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="6"/>

                        <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="7"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="8"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="9"/>

                        <Button Grid.Row="3" Grid.Column="0" Content="C" Style="{StaticResource BotaoTeclado}"
                                Background="#DC3545" Command="{Binding LimparCampoCommand}"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource BotaoTeclado}"
                                Command="{Binding TeclaNumericaCommand}" CommandParameter="0"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="►" Style="{StaticResource BotaoTeclado}"
                                Background="#007ACC" FontSize="14"
                                Command="{Binding SelecionarCampoCommand}" 
                                CommandParameter="alternar" ToolTip="Alternar campo"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <GroupBox Grid.Row="3" Header="Programas Pré-definidos"
                  Foreground="White" BorderBrush="#007ACC" Margin="0,5">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="Pipoca" Style="{StaticResource BotaoPrograma}"
                        Command="{Binding SelecionarProgramaCommand}"
                        CommandParameter="Pipoca"/>
                <Button Content="Leite" Style="{StaticResource BotaoPrograma}"
                        Command="{Binding SelecionarProgramaCommand}"
                        CommandParameter="Leite"/>
                <Button Content="Carne" Style="{StaticResource BotaoPrograma}"
                        Command="{Binding SelecionarProgramaCommand}"
                        CommandParameter="Carne"/>
                <Button Content="Frango" Style="{StaticResource BotaoPrograma}"
                        Command="{Binding SelecionarProgramaCommand}"
                        CommandParameter="Frango"/>
                <Button Content="Feijão" Style="{StaticResource BotaoPrograma}"
                        Command="{Binding SelecionarProgramaCommand}"
                        CommandParameter="Feijao"/>
            </WrapPanel>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10">
            <Button Content="INICIAR" Style="{StaticResource BotaoAcao}"
                    Background="#28A745" Foreground="White"
                    Command="{Binding IniciarCommand}"/>
            <Button Content="PARAR" Style="{StaticResource BotaoAcao}"
                    Background="#DC3545" Foreground="White"
                    Command="{Binding PararCommand}"/>
        </StackPanel>

        <GroupBox Grid.Row="5" Header="Novo Programa Customizado"
                  Foreground="White" BorderBrush="#007ACC" Margin="0,5">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome:" Foreground="White" 
                           VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                         Text="{Binding NovoNome, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3E3E42" Foreground="White" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Alimento:" Foreground="White" 
                           VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                         Text="{Binding NovoAlimento, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3E3E42" Foreground="White" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tempo(s):" Foreground="White" 
                           VerticalAlignment="Center" Margin="0,0,5,5"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding NovoTempo, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3E3E42" Foreground="White" Margin="0,0,5,5" Width="50"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Potência:" Foreground="White" 
                           VerticalAlignment="Center" Margin="5,0,5,5"/>
                <TextBox Grid.Row="2" Grid.Column="3"
                         Text="{Binding NovaPotencia, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3E3E42" Foreground="White" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Caracter:" Foreground="White" 
                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding NovoCaracter, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3E3E42" Foreground="White" MaxLength="1" Width="30"
                         HorizontalAlignment="Left"/>
                <Button Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Content="SALVAR"
                        Background="#007ACC" Foreground="White" Margin="5,0,0,0"
                        Command="{Binding SalvarCustomizadoCommand}" Cursor="Hand"/>
            </Grid>
        </GroupBox>

        <Border Grid.Row="6" Background="#3E3E42"
                CornerRadius="5" Padding="10" Margin="0,5,0,0">
            <TextBlock Text="{Binding Instrucoes}"
                       Foreground="#CCCCCC" TextWrapping="Wrap"
                       FontStyle="Italic" FontSize="11"/>
        </Border>
    </Grid>
</Window>
